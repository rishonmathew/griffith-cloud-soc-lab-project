options {
    directory "/var/cache/bind";

    // Only accept queries from our own networks — not the internet
    allow-query { 127.0.0.1; 192.168.1.0/24; 10.10.1.0/24; };

    // Send queries we can't answer ourselves to Google's DNS
    forwarders {
        8.8.8.8;
        8.8.4.4;
    };
    forward only;

    // Validate DNSSEC signatures using the built-in root zone trust anchors
    dnssec-validation auto;

    // Listen on localhost and both network interfaces
    listen-on { 127.0.0.1; 192.168.1.1; 10.10.1.254; };
    listen-on-v6 { none; };
};